menuconfig PRECISION_TIMING
	bool "Precision timing infrastructure [EXPERIMENTAL]"
	select EXPERIMENTAL
	help
	  Enable experimental protocol-neutral precision timing helpers for
	  domain-qualified timestamps, clock adapters, mappings, and clock
	  discipline.
